{# Apple nav link list item #}
{% set nav_display = display|default('text') %}
{% set nav_icon = icon|default('none') %}

<li class="apple-global-nav__item">
  <a href="{{ url }}" class="apple-global-nav__link" aria-label="{{ title }}">
    {% if nav_display == 'icon' and nav_icon != 'none' %}
      <span class="apple-global-nav__icon" aria-hidden="true">
        {% if nav_icon == 'search' %}
          <svg viewBox="0 0 15 15" xmlns="http://www.w3.org/2000/svg"><path d="M10.67 9.61l3.42 3.42a.75.75 0 1 1-1.06 1.06l-3.42-3.42a5.5 5.5 0 1 1 1.06-1.06zM6.5 10.5a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/></svg>
        {% elseif nav_icon == 'bag' %}
          <svg viewBox="0 0 17 17" xmlns="http://www.w3.org/2000/svg"><path d="M12.6 6.1h-1a3.1 3.1 0 0 0-6.2 0h-1A2.1 2.1 0 0 0 2.3 8.2v5.7A2.1 2.1 0 0 0 4.4 16h8.2a2.1 2.1 0 0 0 2.1-2.1V8.2A2.1 2.1 0 0 0 12.6 6.1zm-4.1-2a2 2 0 0 1 2 2h-4a2 2 0 0 1 2-2zm4.4 9.8a1 1 0 0 1-1 1H4.1a1 1 0 0 1-1-1V8.2a1 1 0 0 1 1-1h7.8a1 1 0 0 1 1 1z"/></svg>
        {% endif %}
      </span>
      <span class="apple-global-nav__label apple-global-nav__label--visually-hidden">{{ title }}</span>
    {% else %}
      <span class="apple-global-nav__label">{{ title }}</span>
    {% endif %}
  </a>
</li>
