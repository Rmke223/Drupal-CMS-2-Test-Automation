# Copy to .env.playwright for local defaults.
PW_SITE=default

# Optional: override auto-detected site URL.
# PW_BASE_URL=https://my-cms2-site.ddev.site

# Start command used by Playwright webServer unless PW_SKIP_WEB_SERVER=1.
PW_DRUPAL_START_CMD=ddev start
PW_SKIP_WEB_SERVER=1
PW_SKIP_READY_CHECK=0
PW_READY_TIMEOUT_MS=120000
PW_RUN_SEED=1

# Admin creds used by authenticated tests.
# Keep secrets in your local .env.playwright or CI secrets.
PW_ADMIN_USER=admin
PW_ADMIN_PASS=admin
